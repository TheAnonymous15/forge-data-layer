# ============================================================
# ForgeForth Africa Data Layer - Environment Configuration
# ============================================================
# The Data Layer is the ONLY service with direct database access.
# All other services (API, Portals) communicate through this layer.

# Environment
DATA_LAYER_ENV=development
DEBUG=True
SECRET_KEY=data-layer-secret-key-change-in-production-xyz789

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,data.forgeforthafrica.com

# Database (Neon PostgreSQL)
DATABASE_URL=sqlite:///data_layer.sqlite3

# ============================================================
# API Service Authentication
# ============================================================
# Only the API service can communicate with the data layer
DATA_LAYER_API_KEY=data-layer-api-key-dev-change-in-production
DATA_LAYER_SIGNING_KEY=data-layer-signing-key-dev-change-in-production
REQUIRE_DATA_LAYER_SIGNING=False
ALLOWED_SERVICE_IDS=api-service

# Redis/Cache
REDIS_URL=redis://localhost:6379/2

# JWT Settings (for generating tokens)
JWT_SECRET_KEY=jwt-secret-key-for-forgeforth-africa-change-in-production
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:9001,http://localhost:9002

# Logging
LOG_LEVEL=DEBUG

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.forgeforthafrica.com
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@forgeforthafrica.com
EMAIL_HOST_PASSWORD=Engdrd,*9930@#
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ForgeForth Africa <mailer@forgeforthafrica.com>
CONTACT_EMAIL=info@forgeforthafrica.com
SUPPORT_EMAIL=support@forgeforthafrica.com

# Test Database for Development
TEST_DATABASE_URL=sqlite:///test_data_layer.sqlite3

