# ============================================================
# ForgeForth Africa - Data Layer Configuration
# ============================================================
# The Data Layer is the SINGLE SOURCE OF TRUTH for all databases.
# All other services communicate with Data Layer via REST API.
# ============================================================

# Environment (development / production)
DATA_LAYER_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Server Configuration
DATA_LAYER_HOST=0.0.0.0
DATA_LAYER_PORT=9010

# ============================================================
# Database Strategy
# ============================================================
# USE_SINGLE_DATABASE=True  -> All tables in one database (dev/simple hosting)
# USE_SINGLE_DATABASE=False -> Multi-database (production/scale)
# USE_NEON_POSTGRES=True    -> Use Neon PostgreSQL (cloud)
# USE_NEON_POSTGRES=False   -> Use local SQLite (dev)
# ============================================================
USE_SINGLE_DATABASE=True
USE_NEON_POSTGRES=False

# ============================================================
# DEVELOPMENT: SQLite (fast, no setup)
# ============================================================
DATABASE_URL=sqlite:///data_layer.sqlite3

# ============================================================
# PRODUCTION: Neon PostgreSQL
# ============================================================
# When USE_SINGLE_DATABASE=True and USE_NEON_POSTGRES=True:
# NEON_MAIN_URL=postgresql://user:pass@host/forgeforth_main?sslmode=require

# ============================================================
# Multi-Database Configuration (USE_SINGLE_DATABASE=False)
# Each domain has its own isolated database for scale
# ============================================================

# Users & Authentication
# NEON_ACCOUNTS_URL=postgresql://user:pass@host/forgeforth_accounts?sslmode=require

# Talent Profiles, Skills, Education, Experience
# NEON_PROFILES_URL=postgresql://user:pass@host/forgeforth_profiles?sslmode=require

# Organizations, Employers, Partners
# NEON_ORGANIZATIONS_URL=postgresql://user:pass@host/forgeforth_organizations?sslmode=require

# Job/Opportunity Listings
# NEON_OPPORTUNITIES_URL=postgresql://user:pass@host/forgeforth_opportunities?sslmode=require

# Applications & Workflows
# NEON_APPLICATIONS_URL=postgresql://user:pass@host/forgeforth_applications?sslmode=require

# Tokens (Verification, Reset, 2FA)
# NEON_TOKENS_URL=postgresql://user:pass@host/forgeforth_tokens?sslmode=require

# Audit Logs & Compliance
# NEON_AUDIT_URL=postgresql://user:pass@host/forgeforth_audit?sslmode=require

# ============================================================
# Redis (caching & sessions)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# CORS - Services allowed to call Data Layer
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:9001,http://localhost:9002,http://localhost:9003,http://localhost:9004

# ============================================================
# JWT Settings
# ============================================================
JWT_SECRET_KEY=your-jwt-secret-key-must-match-other-services
JWT_ALGORITHM=HS256

# ============================================================
# Service-to-Service Authentication
# ============================================================
# API key that other services must provide to access Data Layer
DATA_LAYER_API_KEY=dl_sk_your-secure-api-key-here

# Services allowed to call Data Layer (comma-separated)
ALLOWED_SERVICE_IDS=api-service,website,talent-portal,org-portal,admin-portal,auth-service

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=DEBUG

